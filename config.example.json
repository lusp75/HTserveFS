{
  "server": {
    "port": 8080,
    "host": "0.0.0.0",
    "tls": {
      "enabled": true,
      "cert_file": "cert.pem",
      "key_file": "key.pem",
      "auto_cert": true
    }
  },
  "files": {
    "shares": [
      {
        "path": "./shared",
        "alias": "Shared",
        "readonly": false
      },
      {
        "path": "./public",
        "alias": "Public",
        "readonly": true
      }
    ],
    "max_file_size": "100MB",
    "allowed_extensions": ["*"]
  },
  "auth": {
    "users": [
      {
        "username": "admin",
        "password_hash": "$2b$12$LQv3c1yqBWVHxkd0LHAkCOYz6TtxMQJqhN8/LewdBPj/RK.s5uO9G",
        "role": "admin"
      },
      {
        "username": "user",
        "password_hash": "$2b$12$92IXUNpkjO0rOQ5byMi.Ye4oKoEa3Ro9llC/.og/at2.uheWG/igi",
        "role": "read-write"
      },
      {
        "username": "guest",
        "password_hash": "$2b$12$gLAaVytqk5.MjZ4x/FVdKONWr8T8nqjjjjjjjjjjjjjjjjjjjjjjjj",
        "role": "read-only"
      }
    ],
    "lockout_threshold": 5,
    "lockout_duration": "15m",
    "session_timeout": "24h",
    "jwt_secret": "your-super-secret-jwt-key-change-this-in-production"
  },
  "throttling": {
    "default_kbps": 1024,
    "per_user_limits": {
      "admin": 0,
      "user": 512,
      "guest": 256
    }
  },
  "logging": {
    "level": "info",
    "file": "htservefs.log",
    "max_size": "10MB",
    "rotate": true
  }
}